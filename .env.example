# =============================================================================
# STAYZY – Environment Variables Example
# Copy file này thành .env.local (FE) hoặc .env (BE) và điền giá trị thật
# KHÔNG BAO GIỜ commit file .env thật lên git
# =============================================================================

# -----------------------------------------------------------------------------
# FRONTEND (fe/) – đặt trong fe/.env.local
# -----------------------------------------------------------------------------

# URL của Backend API
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Sentry DSN cho Frontend (lấy từ sentry.io)
NEXT_PUBLIC_SENTRY_DSN=

# -----------------------------------------------------------------------------
# BACKEND (be/) – đặt trong be/.env
# -----------------------------------------------------------------------------

# Server
PORT=3001
NODE_ENV=development

# Database – PostgreSQL connection string
# Ví dụ local:    postgresql://postgres:password@localhost:5432/stayzy
# Ví dụ Supabase: postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
# Ví dụ Neon:     postgresql://[user]:[password]@[host]/stayzy?sslmode=require
DATABASE_URL=postgresql://postgres:password@localhost:5432/stayzy

# JWT
JWT_ACCESS_SECRET=your-access-token-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-token-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS – URL của Frontend
CORS_ORIGIN=http://localhost:3000

# Sentry DSN cho Backend (lấy từ sentry.io)
SENTRY_DSN=

# AWS S3 – Upload ảnh
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_BUCKET_NAME=

# Stripe – Thanh toán
# Lấy từ https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Lấy từ https://dashboard.stripe.com/webhooks (sau khi tạo webhook endpoint)
STRIPE_WEBHOOK_SECRET=whsec_...
# URL của Frontend (dùng cho success_url / cancel_url)
FRONTEND_URL=http://localhost:3000
