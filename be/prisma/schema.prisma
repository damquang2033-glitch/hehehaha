generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  avatar       String?
  role         Role     @default(GUEST)
  refreshToken String?
  listings     Listing[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

enum Role {
  GUEST
  HOST
  ADMIN
}

model Listing {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Decimal
  location    String
  images      String[]
  maxGuests   Int?
  bedrooms    Int?
  bathrooms   Int?
  hostId      String
  host        User     @relation(fields: [hostId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
